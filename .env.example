# PostgreSQL
POSTGRES_DB=cloudproxy
POSTGRES_USER=cloudproxy
POSTGRES_PASSWORD=cloudproxy
POSTGRES_PORT=5433
DATABASE_URL=postgres://cloudproxy:cloudproxy@127.0.0.1:5433/cloudproxy?sslmode=disable

# Control Plane
CONTROL_PLANE_ADDR=127.0.0.1:8090
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# Logging
LOG_FORMAT=text
LOG_LEVEL=info
